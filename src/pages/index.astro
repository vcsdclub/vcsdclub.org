---
import Layout from "~/layouts/PageLayout.astro";
import Image from "~/components/common/Image.astro";
import groupPhoto from "~/assets/images/group.webp";

const metadata = {
  title: "Valley Christian Software Development Club",
  ignoreTitleTemplate: true,
};

const overview = [
  {
    title: "Adaptive lectures",
    body: "Calibrated to the room. Whether you've never opened a terminal or you've shipped side projects, you leave with something new.",
  },
  {
    title: "Interactive exercises",
    body: "You don't learn to code by watching. We break lectures with short problems so the ideas land in your hands before they leave the room.",
  },
  {
    title: "Workshops",
    body: "We build things together. Mentors circulate, questions get answered, and everyone walks out with working code.",
  },
  {
    title: "Build season",
    body: "Second semester, you take what you've learned and make something real. Your idea, our mentorship, real software at the end.",
  },
  {
    title: "On-demand mentoring",
    body: "Stuck between meetings? Email us. We'd rather answer questions than let anyone spin their wheels.",
  },
  {
    title: "Zero cost. Always.",
    body: "All our resources are free — even if you don't go to Valley Christian. We mean it.",
  },
];
---

<Layout metadata={metadata}>
  <!-- HERO -->
  <section class="page-gutter pt-12 md:pt-20">
    <div class="grid grid-cols-12 gap-x-6 gap-y-10 items-end">
      <!-- left: path + statement -->
      <div class="col-span-12 lg:col-span-7">
        <p class="path mb-10">~/index.astro</p>

        <h1
          class="display text-ink"
          style="font-size: clamp(2.75rem, 8.5vw, 7rem);"
        >
          Build real<br />software.
        </h1>

        <p class="prose-lead mt-8 max-w-[52ch]">
          A student-run club at Valley Christian High School. We teach the
          craft of engineering the way it's actually practiced — messily,
          collaboratively, one shipped version at a time. No contest grinding.
          No résumé theatre.
        </p>

        <div class="mt-10 flex flex-wrap items-center gap-8">
          <a
            href="https://forms.gle/pUcXkLxdX5tV6BfX6"
            target="_blank"
            rel="noopener noreferrer"
            class="prompt"
          >
            join mailing list
            <span class="arrow" aria-hidden="true">→</span>
          </a>
          <a href="#overview" class="mono text-[0.8125rem] text-ink-soft hover:text-accent transition-colors">
            what we do ↓
          </a>
        </div>
      </div>

      <!-- right: photo with mono caption -->
      <aside class="col-span-12 lg:col-span-5">
        <figure>
          <Image
            src={groupPhoto}
            alt="Members of the Software Development Club"
            widths={[480, 960, 1400]}
            sizes="(max-width: 1024px) 100vw, 40vw"
            class="w-full h-auto block"
          />
          <figcaption
            class="mt-3 flex items-baseline gap-3 border-t border-rule-soft pt-2"
          >
            <span class="lineno">fig.01</span>
            <span class="caption">the club — fall, 2024</span>
          </figcaption>
        </figure>
      </aside>
    </div>
  </section>

  <!-- QUOTE -->
  <section class="page-gutter mt-32 md:mt-44">
    <div class="grid grid-cols-12 gap-6">
      <div class="col-span-12 lg:col-span-1 lg:pt-2">
        <p class="section-numeral">§ 01</p>
      </div>
      <figure class="col-span-12 lg:col-span-9 lg:col-start-3 border-t border-rule pt-10">
        <p class="path mb-10">~/quotes/from-the-president</p>
        <blockquote class="text-ink">
          <p
            class="display-tight"
            style="font-size: clamp(2rem, 4.5vw, 3.75rem);"
          >
            I take this very seriously.
          </p>
          <p
            class="display-tight mt-8 text-ink-soft max-w-[58ch]"
            style="font-size: clamp(1.0625rem, 1.3vw, 1.1875rem); line-height: 1.55; font-stretch: 100%; font-weight: 400; letter-spacing: 0;"
          >
            Too many kids these days are forced into learning programming,
            especially competitive programming. So they learn, because they
            were forced to learn. But then afterwards, they realize that their
            skills are put to waste as they did not know how to put them into
            practical use.
          </p>
          <p
            class="display-tight mt-8"
            style="font-size: clamp(1.625rem, 3vw, 2.5rem); color: var(--aw-color-accent);"
          >
            I want to change that with this club.
          </p>
        </blockquote>
        <figcaption
          class="mt-10 flex items-baseline gap-3 border-t border-rule-soft pt-3"
        >
          <span class="lineno">—</span>
          <span class="mono text-[0.8125rem] text-ink">Bryan Hu</span>
          <span class="caption">co-president</span>
        </figcaption>
      </figure>
    </div>
  </section>

  <!-- OVERVIEW -->
  <section id="overview" class="page-gutter mt-32 md:mt-44">
    <div class="grid grid-cols-12 gap-6">
      <div class="col-span-12 lg:col-span-1 lg:pt-2">
        <p class="section-numeral">§ 02</p>
      </div>
      <header class="col-span-12 lg:col-span-11 border-t border-rule pt-10 pb-14 md:pb-16">
        <p class="path mb-6">~/program</p>
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 items-baseline">
          <h2
            class="display-tight text-ink lg:col-span-7"
            style="font-size: clamp(1.75rem, 3.4vw, 2.875rem);"
          >
            A year of learning,<br />built around making things.
          </h2>
          <p class="text-ink-soft leading-relaxed lg:col-span-4 lg:col-start-9 text-[0.9375rem]">
            One weekly meeting. A first semester of fundamentals, a second of
            building. Everything below is what happens in between.
          </p>
        </div>
      </header>
    </div>

    <ol class="grid grid-cols-1 md:grid-cols-2 border-t border-rule border-l-0 md:border-l border-rule-soft">
      {
        overview.map((item, i) => (
          <li
            class:list={[
              "grid grid-cols-[auto_1fr] gap-5 p-6 md:p-8 border-b border-rule-soft",
              i % 2 === 0 && "md:border-r md:border-rule-soft",
            ]}
          >
            <span class="lineno pt-1">
              {String(i + 1).padStart(2, "0")}
            </span>
            <div>
              <h3
                class="display-tight text-ink mb-2"
                style="font-size: 1.25rem;"
              >
                {item.title}
              </h3>
              <p class="text-ink-soft leading-relaxed text-[0.9375rem] max-w-prose">
                {item.body}
              </p>
            </div>
          </li>
        ))
      }
    </ol>
  </section>
</Layout>
