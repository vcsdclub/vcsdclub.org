---
import Layout from "~/layouts/PageLayout.astro";
import Image from "~/components/common/Image.astro";
import groupPhoto from "~/assets/images/group.webp";

const metadata = {
  title: "Valley Christian Software Development Club",
  ignoreTitleTemplate: true,
};

const issueDate = new Date().toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
});

const overview = [
  {
    n: "01",
    title: "Adaptive lectures",
    body: "Lectures calibrated to the room — so whether you've never touched a terminal or you've shipped side projects, you leave with something new.",
  },
  {
    n: "02",
    title: "Interactive exercises",
    body: "You don't learn to code by watching. We break lectures with short problems so the ideas land in your hands before they leave the room.",
  },
  {
    n: "03",
    title: "Workshops",
    body: "We build things together. Mentors circulate, questions get answered, and everyone walks out with working code.",
  },
  {
    n: "04",
    title: "Semester 2: build season",
    body: "The back half of the year, you take what you've learned and make something real — your idea, our mentorship, real software at the end.",
  },
  {
    n: "05",
    title: "Mentoring, on-demand",
    body: "Stuck between meetings? Email us. We'd rather answer questions than let you spin your wheels.",
  },
  {
    n: "06",
    title: "Zero cost. Always.",
    body: "All of our resources are free — even if you don't go to Valley Christian. We mean it.",
  },
];
---

<Layout metadata={metadata}>
  <!-- ══════════ HERO ══════════ -->
  <section class="px-6 md:px-10 pt-8 md:pt-14">
    <div class="mx-auto w-full max-w-[1400px]">
      <!-- Masthead metadata -->
      <div
        class="flex flex-wrap items-center justify-between gap-4 pb-6 border-b border-rule"
      >
        <p class="label">
          <span class="text-ink">VOL.&nbsp;I</span> · {issueDate} · VCHS
        </p>
        <p class="label hidden sm:block">
          A publication of the Software Development Club
        </p>
        <p class="label">№ 001</p>
      </div>

      <!-- Headline grid -->
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 pt-10 md:pt-16">
        <div class="lg:col-span-7">
          <p class="label mb-6">§ Issue&nbsp;One — The Manifesto</p>
          <h1
            class="serif-display text-[14vw] sm:text-[11vw] lg:text-[8.5vw] xl:text-[7.2rem] text-ink"
          >
            Build real<br />
            <span class="italic">software</span>,<br />
            <span class="underline-accent">not résumés</span>.
          </h1>

          <p
            class="mt-10 text-ink-soft text-lg md:text-xl leading-relaxed max-w-xl font-sans"
          >
            The <abbr title="Valley Christian High School">VCHS</abbr> Software
            Development Club exists for one reason: to help you build things that
            actually work. No grinding contest problems. No résumé-stuffing. Just
            the craft of engineering, taught by students who love it.
          </p>

          <div class="mt-10 flex flex-wrap items-center gap-4">
            <a
              href="https://forms.gle/pUcXkLxdX5tV6BfX6"
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-primary"
            >
              Join the mailing list
              <span aria-hidden="true">↗</span>
            </a>
            <a href="#overview" class="btn">Read more</a>
          </div>
        </div>

        <!-- Sidebar: photo + cutline -->
        <aside class="lg:col-span-5 lg:pt-20">
          <figure>
            <div class="relative overflow-hidden border border-rule bg-raised">
              <Image
                src={groupPhoto}
                alt="The four club officers"
                widths={[400, 800, 1200]}
                sizes="(max-width: 1024px) 100vw, 40vw"
                class="w-full h-auto block"
              />
            </div>
            <figcaption
              class="mt-3 font-mono text-xs text-muted leading-relaxed"
            >
              <span class="text-accent">Fig.&nbsp;1 —</span> The officers, 2024–2025.
              From left: Bryan Hu, Amaar Chughtai, Ryan Abraham, Maya Rao.
            </figcaption>
          </figure>
        </aside>
      </div>
    </div>
  </section>

  <!-- ══════════ PULL QUOTE ══════════ -->
  <section class="px-6 md:px-10 mt-24 md:mt-36">
    <div class="mx-auto w-full max-w-[1100px]">
      <div class="rule-thick mb-10"></div>
      <blockquote class="serif-head text-3xl md:text-5xl text-ink leading-[1.1]">
        <span aria-hidden="true" class="text-accent italic">“</span>Too many kids
        these days are forced into learning programming — so they learn, because
        they were forced to. Then they realize their skills are put to waste, because
        <span class="italic">they never learned how to use them</span>.<span
          aria-hidden="true"
          class="text-accent italic">”</span
        >
      </blockquote>
      <p class="mt-8 label">
        <span class="text-ink">Bryan Hu</span> — Co-President, on why this club exists
      </p>
    </div>
  </section>

  <!-- ══════════ OVERVIEW ══════════ -->
  <section id="overview" class="px-6 md:px-10 mt-32 md:mt-48">
    <div class="mx-auto w-full max-w-[1400px]">
      <header
        class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 pb-8 border-b-2 border-rule"
      >
        <div>
          <p class="label mb-3">§ 02 — What we do</p>
          <h2 class="serif-head text-5xl md:text-7xl text-ink leading-none">
            Six things, done well.
          </h2>
        </div>
        <p class="text-muted max-w-sm md:text-right">
          A weekly meeting. A year of learning. A project you'll actually be
          proud to put in front of someone.
        </p>
      </header>

      <ol class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3">
        {
          overview.map((item, i) => (
            <li
              class:list={[
                "border-b border-rule px-0 py-10 md:p-10 flex flex-col gap-4",
                i % 3 !== 2 && "lg:border-r",
                i % 2 !== 1 && "md:max-lg:border-r",
              ]}
            >
              <span class="font-mono text-sm text-accent tracking-widest">
                {item.n}
              </span>
              <h3 class="serif-head text-2xl md:text-3xl text-ink leading-tight">
                {item.title}
              </h3>
              <p class="text-muted leading-relaxed">{item.body}</p>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <!-- ══════════ CTA STRIP ══════════ -->
  <section class="px-6 md:px-10 mt-32 md:mt-40">
    <div class="mx-auto w-full max-w-[1400px]">
      <div
        class="border border-rule bg-raised px-8 md:px-14 py-14 md:py-20 grid md:grid-cols-12 gap-8 items-center"
      >
        <div class="md:col-span-8">
          <p class="label mb-4">Next issue drops when you sign up</p>
          <p class="serif-head text-4xl md:text-6xl text-ink leading-[1.05]">
            Want to build<br />something real?
          </p>
        </div>
        <div class="md:col-span-4 flex flex-wrap gap-3 md:justify-end">
          <a
            href="https://forms.gle/pUcXkLxdX5tV6BfX6"
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-primary"
          >
            Join the list
            <span aria-hidden="true">↗</span>
          </a>
          <a href="/about" class="btn">Meet the team</a>
        </div>
      </div>
    </div>
  </section>
</Layout>
