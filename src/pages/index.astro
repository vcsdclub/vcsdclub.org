---
import Layout from "~/layouts/PageLayout.astro";
import Image from "~/components/common/Image.astro";
import groupPhoto from "~/assets/images/group.webp";

const metadata = {
  title: "Valley Christian Software Development Club",
  ignoreTitleTemplate: true,
};

const overview = [
  {
    title: "Adaptive lectures",
    body: "Calibrated to the room. Whether you've never opened a terminal or you've shipped side projects, you leave with something new.",
  },
  {
    title: "Interactive exercises",
    body: "You don't learn to code by watching. We break lectures with short problems so the ideas land in your hands before they leave the room.",
  },
  {
    title: "Workshops",
    body: "We build things together. Mentors circulate, questions get answered, and everyone walks out with working code.",
  },
  {
    title: "Build season",
    body: "Second semester, you take what you've learned and make something real. Your idea, our mentorship, real software at the end.",
  },
  {
    title: "On-demand mentoring",
    body: "Stuck between meetings? Email us. We'd rather answer questions than let anyone spin their wheels.",
  },
  {
    title: "Zero cost. Always.",
    body: "All our resources are free — even if you don't go to Valley Christian. We mean it.",
  },
];

const timeline = [
  {
    phase: "Sep",
    title: "Welcome & fundamentals",
    body: "We meet you where you are. Terminal, Git, the shape of a program.",
  },
  {
    phase: "Oct–Dec",
    title: "Building blocks",
    body: "Data, control flow, structure. Short problems, hands on keys, mentors beside you.",
  },
  {
    phase: "Jan",
    title: "Pitch your project",
    body: "You decide what to build. Solo, pair, or small team. We help you scope it.",
  },
  {
    phase: "Feb–May",
    title: "Build season",
    body: "One weekly standup, open help hours, a shipped project at the end.",
  },
];
---

<Layout metadata={metadata}>
  <!-- 01 — TERMINAL HERO -->
  <section class="page-gutter pt-10 md:pt-20 min-h-[92vh] flex flex-col justify-between">
    <div>
      <p class="path mb-8">~/vcsdclub $ <span data-anim="typeline">whoami</span></p>

      <h1
        class="display text-ink"
        style="font-size: clamp(2.75rem, 10vw, 9rem);"
      >
        <span class="block" data-anim="rise">Build real</span>
        <span class="block" data-anim="rise" style="color: var(--aw-color-accent);">software<span data-cursor></span></span>
      </h1>

      <div class="mt-10 grid grid-cols-12 gap-x-6 gap-y-8 items-start">
        <p class="prose-lead col-span-12 lg:col-span-6 max-w-[52ch]" data-anim="reveal">
          A student-run club at Valley Christian High School. We teach the
          craft of engineering the way it's actually practiced — messily,
          collaboratively, one shipped version at a time. No contest grinding.
          No résumé theatre.
        </p>

        <div class="col-span-12 lg:col-span-5 lg:col-start-8" data-anim="reveal">
          <figure>
            <Image
              src={groupPhoto}
              alt="Members of the Software Development Club"
              widths={[480, 960, 1400]}
              sizes="(max-width: 1024px) 100vw, 40vw"
              class="w-full h-auto block"
            />
            <figcaption
              class="mt-3 flex items-baseline gap-3 border-t border-rule-soft pt-2"
            >
              <span class="lineno">fig.01</span>
              <span class="caption">the club — fall, 2024</span>
            </figcaption>
          </figure>
        </div>
      </div>
    </div>

    <div class="mt-14 flex flex-wrap items-center gap-8 border-t border-rule-soft pt-6">
      <a
        href="https://forms.gle/pUcXkLxdX5tV6BfX6"
        target="_blank"
        rel="noopener noreferrer"
        class="prompt"
      >
        join mailing list
        <span class="arrow" aria-hidden="true">→</span>
      </a>
      <a href="#manifesto" class="mono text-[0.8125rem] text-ink-soft hover:text-accent transition-colors">
        read the manifesto ↓
      </a>
    </div>
  </section>

  <!-- 02 — STATS STRIP -->
  <section class="page-gutter mt-24 md:mt-32">
    <div class="border-y border-rule py-10 md:py-14 grid grid-cols-2 md:grid-cols-4 gap-y-8" data-anim="stagger">
      <div>
        <p class="tag mb-3">members</p>
        <p class="display text-ink" style="font-size: clamp(2rem, 4vw, 3.25rem);"><span data-anim="count" data-to="60">0</span>+</p>
      </div>
      <div>
        <p class="tag mb-3">weekly meetings</p>
        <p class="display text-ink" style="font-size: clamp(2rem, 4vw, 3.25rem);"><span data-anim="count" data-to="1">0</span></p>
      </div>
      <div>
        <p class="tag mb-3">cost to join</p>
        <p class="display text-ink" style="font-size: clamp(2rem, 4vw, 3.25rem);">$0</p>
      </div>
      <div>
        <p class="tag mb-3">build season, months</p>
        <p class="display text-ink" style="font-size: clamp(2rem, 4vw, 3.25rem);"><span data-anim="count" data-to="4">0</span></p>
      </div>
    </div>
  </section>

  <!-- 03 — MANIFESTO (full-bleed) -->
  <section id="manifesto" class="page-gutter mt-32 md:mt-48">
    <div class="grid grid-cols-12 gap-6">
      <div class="col-span-12 lg:col-span-1 lg:pt-2">
        <p class="section-numeral">§ 01 — manifesto</p>
      </div>
      <figure class="col-span-12 lg:col-span-10 lg:col-start-3">
        <div class="h-px bg-rule" data-anim="draw"></div>
        <p class="path mt-8 mb-10">~/quotes/from-the-president</p>
        <blockquote class="text-ink">
          <p
            class="display-tight"
            data-anim="reveal"
            style="font-size: clamp(2.25rem, 6vw, 5.25rem);"
          >
            I take this very seriously.
          </p>
          <p
            class="display-tight mt-10 text-ink-soft max-w-[62ch]"
            data-anim="reveal"
            style="font-size: clamp(1.0625rem, 1.3vw, 1.1875rem); line-height: 1.6; font-stretch: 100%; font-weight: 400; letter-spacing: 0;"
          >
            Too many kids these days are forced into learning programming,
            especially competitive programming. So they learn, because they
            were forced to learn. But then afterwards, they realize that their
            skills are put to waste as they did not know how to put them into
            practical use.
          </p>
          <p
            class="display-tight mt-10"
            data-anim="reveal"
            style="font-size: clamp(1.75rem, 4vw, 3.25rem); color: var(--aw-color-accent);"
          >
            I want to change that with this club.
          </p>
        </blockquote>
        <figcaption
          class="mt-12 flex items-baseline gap-3 border-t border-rule-soft pt-3"
        >
          <span class="lineno">—</span>
          <span class="mono text-[0.8125rem] text-ink">Bryan Hu</span>
          <span class="caption">co-president</span>
        </figcaption>
      </figure>
    </div>
  </section>

  <!-- 04 — PROGRAM OVERVIEW -->
  <section class="page-gutter mt-32 md:mt-44">
    <div class="grid grid-cols-12 gap-6">
      <div class="col-span-12 lg:col-span-1 lg:pt-2">
        <p class="section-numeral">§ 02 — program</p>
      </div>
      <header class="col-span-12 lg:col-span-11 border-t border-rule pt-10 pb-14 md:pb-16">
        <p class="path mb-6">~/program</p>
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 items-baseline">
          <h2
            class="display-tight text-ink lg:col-span-7"
            data-anim="reveal"
            style="font-size: clamp(1.75rem, 3.4vw, 2.875rem);"
          >
            A year of learning,<br />built around making things.
          </h2>
          <p class="text-ink-soft leading-relaxed lg:col-span-4 lg:col-start-9 text-[0.9375rem]" data-anim="reveal">
            One weekly meeting. A first semester of fundamentals, a second of
            building. Everything below is what happens in between.
          </p>
        </div>
      </header>
    </div>

    <ol class="grid grid-cols-1 md:grid-cols-2 border-t border-rule border-l-0 md:border-l border-rule-soft" data-anim="stagger">
      {
        overview.map((item, i) => (
          <li
            class:list={[
              "grid grid-cols-[auto_1fr] gap-5 p-6 md:p-8 border-b border-rule-soft",
              i % 2 === 0 && "md:border-r md:border-rule-soft",
            ]}
          >
            <span class="lineno pt-1">
              {String(i + 1).padStart(2, "0")}
            </span>
            <div>
              <h3
                class="display-tight text-ink mb-2"
                style="font-size: 1.25rem;"
              >
                {item.title}
              </h3>
              <p class="text-ink-soft leading-relaxed text-[0.9375rem] max-w-prose">
                {item.body}
              </p>
            </div>
          </li>
        ))
      }
    </ol>
  </section>

  <!-- 05 — THE YEAR (horizontal timeline) -->
  <section class="mt-32 md:mt-44">
    <div class="page-gutter">
      <div class="grid grid-cols-12 gap-6">
        <div class="col-span-12 lg:col-span-1 lg:pt-2">
          <p class="section-numeral">§ 03 — the year</p>
        </div>
        <header class="col-span-12 lg:col-span-11 border-t border-rule pt-10 pb-10">
          <p class="path mb-6">~/program/timeline</p>
          <h2
            class="display-tight text-ink"
            data-anim="reveal"
            style="font-size: clamp(1.75rem, 3.4vw, 2.875rem);"
          >
            How the year moves.
          </h2>
        </header>
      </div>
    </div>

    <div class="page-gutter">
      <div class="h-px bg-rule" data-anim="draw"></div>
      <ol class="grid grid-cols-1 md:grid-cols-4" data-anim="stagger">
        {
          timeline.map((t, i) => (
            <li
              class:list={[
                "py-10 md:py-14 pr-6 border-b md:border-b-0 border-rule-soft",
                i < timeline.length - 1 && "md:border-r md:border-rule-soft md:pl-6",
                i === 0 && "md:pl-0",
              ]}
            >
              <p class="tag mb-4">{t.phase}</p>
              <h3
                class="display-tight text-ink mb-3"
                style="font-size: clamp(1.125rem, 1.6vw, 1.375rem);"
              >
                {t.title}
              </h3>
              <p class="text-ink-soft leading-relaxed text-[0.9375rem]">
                {t.body}
              </p>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <!-- 06 — CLOSING CTA -->
  <section class="page-gutter mt-32 md:mt-48">
    <div class="border-t border-rule pt-14 md:pt-20">
      <p class="path mb-6">~/join</p>
      <h2
        class="display text-ink max-w-[18ch]"
        data-anim="reveal"
        style="font-size: clamp(2.5rem, 7vw, 6rem);"
      >
        Come build something.
      </h2>
      <p class="prose-lead mt-8 max-w-[52ch]" data-anim="reveal">
        Meetings are open. The curriculum is free. The mentors are already
        here. The only thing missing is you.
      </p>
      <div class="mt-12 flex flex-wrap items-center gap-8">
        <a
          href="https://forms.gle/pUcXkLxdX5tV6BfX6"
          target="_blank"
          rel="noopener noreferrer"
          class="prompt"
        >
          join mailing list
          <span class="arrow" aria-hidden="true">→</span>
        </a>
        <a href="/about" class="mono text-[0.8125rem] text-ink-soft hover:text-accent transition-colors">
          meet the team →
        </a>
      </div>
    </div>
  </section>
</Layout>
