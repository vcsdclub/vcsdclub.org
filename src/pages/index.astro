---
import Layout from "~/layouts/PageLayout.astro";
import Image from "~/components/common/Image.astro";
import groupPhoto from "~/assets/images/group.webp";

const metadata = {
  title: "Valley Christian Software Development Club",
  ignoreTitleTemplate: true,
};

const overview = [
  {
    title: "Adaptive lectures",
    body: "Calibrated to the room. Whether you've never opened a terminal or you've shipped side projects, you leave with something new.",
  },
  {
    title: "Interactive exercises",
    body: "You don't learn to code by watching. We break lectures with short problems so the ideas land in your hands before they leave the room.",
  },
  {
    title: "Workshops",
    body: "We build things together. Mentors circulate, questions get answered, and everyone walks out with working code.",
  },
  {
    title: "Build season",
    body: "Second semester, you take what you've learned and make something real. Your idea, our mentorship, real software at the end.",
  },
  {
    title: "On-demand mentoring",
    body: "Stuck between meetings? Email us. We'd rather answer questions than let anyone spin their wheels.",
  },
  {
    title: "Zero cost. Always.",
    body: "All our resources are free — even if you don't go to Valley Christian. We mean it.",
  },
];
---

<Layout metadata={metadata}>
  <!-- HERO -->
  <section class="page-gutter pt-10 md:pt-20">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-[clamp(2rem,5vw,5rem)] items-end">
      <div class="lg:col-span-7 xl:col-span-7">
        <p class="eyebrow mb-8 accent-dot">Software Development Club at VCHS</p>
        <h1
          class="display text-ink"
          style="font-size: clamp(3rem, 8.5vw, 6rem);"
        >
          Build real<br />
          <span class="italic">software</span>.
        </h1>
        <p class="prose-lead mt-8 max-w-xl">
          We're a student-run club that teaches the craft of engineering the way
          it's actually practiced — messily, collaboratively, one shipped version
          at a time. No contest grinding. No résumé theatre. Just real software.
        </p>
        <div class="mt-10 flex flex-wrap items-center gap-5">
          <a
            href="https://forms.gle/pUcXkLxdX5tV6BfX6"
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-primary"
          >
            Join the mailing list
            <span class="arrow" aria-hidden="true">→</span>
          </a>
          <a href="#overview" class="link text-[0.9375rem]">What we do</a>
        </div>
      </div>

      <aside class="lg:col-span-5 xl:col-span-5">
        <figure>
          <Image
            src={groupPhoto}
            alt="Members of the Software Development Club"
            widths={[480, 960, 1400]}
            sizes="(max-width: 1024px) 100vw, 40vw"
            class="w-full h-auto block bg-raised"
          />
          <figcaption class="caption mt-3">The club, fall 2024.</figcaption>
        </figure>
      </aside>
    </div>
  </section>

  <!-- QUOTE -->
  <section class="page-gutter mt-28 md:mt-40">
    <div class="max-w-[62ch]">
      <p class="eyebrow mb-6">From the editor</p>
      <blockquote
        class="display-tight text-ink"
        style="font-size: clamp(1.25rem, 1.8vw, 1.625rem); line-height: 1.4;"
      >
        I take this very seriously. Too many kids these days are forced into
        learning programming, especially competitive programming. So they learn,
        because they were forced to learn. But then afterwards, they realize
        that their skills are put to waste as they did not know how to put them
        into practical use.
        <span class="italic">I want to change that with this club.</span>
      </blockquote>
      <p class="eyebrow mt-8">
        <span class="text-ink">Bryan Hu</span>, Co-President
      </p>
    </div>
  </section>

  <!-- OVERVIEW -->
  <section id="overview" class="page-gutter mt-28 md:mt-40">
    <header class="grid grid-cols-1 lg:grid-cols-12 gap-6 items-baseline mb-12 md:mb-16">
      <h2
        class="display-tight text-ink lg:col-span-7"
        style="font-size: clamp(1.75rem, 2.8vw, 2.5rem);"
      >
        A year of learning,<br />built around <span class="italic">making things</span>.
      </h2>
      <p class="text-ink-soft leading-relaxed lg:col-span-4 lg:col-start-9">
        One weekly meeting. A first semester of fundamentals, a second of
        building. Everything below is what happens in between.
      </p>
    </header>

    <ol class="grid grid-cols-1 md:grid-cols-2 gap-x-[clamp(2rem,4vw,4rem)] gap-y-10">
      {
        overview.map((item, i) => (
          <li class="grid grid-cols-[auto_1fr] gap-5">
            <span
              class="font-mono text-ink-soft pt-[0.3rem]"
              style="font-size: 0.75rem; letter-spacing: 0;"
            >
              {String(i + 1).padStart(2, "0")}
            </span>
            <div>
              <h3
                class="display-tight text-ink mb-2"
                style="font-size: 1.25rem;"
              >
                {item.title}
              </h3>
              <p class="text-ink-soft leading-relaxed max-w-prose">
                {item.body}
              </p>
            </div>
          </li>
        ))
      }
    </ol>
  </section>
</Layout>
