---
import Layout from "~/layouts/PageLayout.astro";
import Image from "~/components/common/Image.astro";
import bryan from "~/assets/images/bryan.webp";
import amaar from "~/assets/images/amaar.jpg";
import ryan from "~/assets/images/ryan.JPG";
import maya from "~/assets/images/maya.jpg";

const metadata = { title: "About" };

const officers = [
  {
    name: "Bryan Hu",
    role: "Co-President",
    image: bryan,
    alt: "Bryan Hu",
    bio: "A passionate software developer who'd rather ship something than talk about it.",
    stats: [
      ["Experience", "5+ yrs programming"],
      ["Languages", "Python, Java, C++, Rust, JS"],
      ["Achievements", "USACO Silver · OSS contributor"],
    ],
  },
  {
    name: "Amaar Chughtai",
    role: "Co-President",
    image: amaar,
    alt: "Amaar Chughtai",
    bio: "15-year-old software engineer in the Bay Area. Builds across the stack and into the model layer.",
    stats: [
      ["Experience", "5+ yrs programming"],
      ["Stack", "Next.js, Svelte (sadly), Astro"],
      ["Focus", "ML — DL, CV, NLP · PyTorch"],
    ],
  },
  {
    name: "Ryan Abraham",
    role: "Vice President",
    image: ryan,
    alt: "Ryan Abraham",
    bio: "High school student interested in programming and robotics mentorship.",
    stats: [
      ["Experience", "5+ yrs programming"],
      ["Background", "Former FTC 21463 team captain"],
      ["Stack", "Java, Python, C++, Svelte, Kotlin"],
    ],
  },
  {
    name: "Maya Rao",
    role: "Head of Business",
    image: maya,
    alt: "Maya Rao",
    bio: "Keeps the operations running so the rest of us can keep building.",
    stats: [],
  },
];

const vision = [
  {
    n: "I",
    title: "Empower",
    body: "Bring out the best in people, and get out of their way so they can build great things.",
  },
  {
    n: "II",
    title: "Impact",
    body: "Create something tangible — for our members, and for the community around us.",
  },
  {
    n: "III",
    title: "Last",
    body: "Not a flash in the pan. A club that outlives its founders and shapes the next generation.",
  },
];
---

<Layout metadata={metadata}>
  <section class="px-6 md:px-10 pt-8 md:pt-14">
    <div class="mx-auto w-full max-w-[1400px]">
      <div
        class="flex flex-wrap items-center justify-between gap-4 pb-6 border-b border-rule"
      >
        <p class="label"><span class="text-ink">§ 03</span> — About</p>
        <p class="label hidden sm:block">Who runs this thing</p>
      </div>

      <div class="pt-10 md:pt-16 grid lg:grid-cols-12 gap-8">
        <div class="lg:col-span-8">
          <p class="label mb-5">A note from the editors</p>
          <h1
            class="serif-display text-[12vw] sm:text-[8vw] lg:text-[6.5vw] xl:text-[6rem] text-ink"
          >
            Built by<br />
            <span class="italic">high schoolers</span>.<br />
            For <span class="underline-accent">high schoolers</span>.
          </h1>
          <p class="mt-10 text-ink-soft text-lg leading-relaxed max-w-xl">
            We're a group of students who got tired of programming being
            taught like a test. This club is the course we wish we'd had —
            real engineering, taught by people who are still figuring it out
            alongside you.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Officers -->
  <section class="px-6 md:px-10 mt-24 md:mt-36">
    <div class="mx-auto w-full max-w-[1400px]">
      <header class="pb-8 border-b-2 border-rule">
        <p class="label mb-3">§ 04 — The officers</p>
        <h2 class="serif-head text-5xl md:text-7xl text-ink">Meet the team.</h2>
      </header>

      {
        officers.map((o, i) => (
          <article
            class:list={[
              "grid md:grid-cols-12 gap-8 md:gap-12 py-14 md:py-20 border-b border-rule",
              i % 2 === 1 && "md:[&_figure]:order-2",
            ]}
          >
            <figure class="md:col-span-5">
              <div class="overflow-hidden border border-rule bg-raised">
                <Image
                  src={o.image}
                  alt={o.alt}
                  widths={[400, 800]}
                  sizes="(max-width: 768px) 100vw, 40vw"
                  class="w-full h-auto block"
                />
              </div>
              <figcaption class="mt-3 font-mono text-xs text-muted">
                <span class="text-accent">Fig.&nbsp;0{i + 2} —</span> {o.name}
              </figcaption>
            </figure>

            <div class="md:col-span-7 flex flex-col justify-center">
              <p class="label mb-3">{o.role}</p>
              <h3 class="serif-head text-5xl md:text-7xl text-ink leading-none">
                {o.name}
              </h3>
              <p class="mt-6 text-ink-soft text-lg leading-relaxed max-w-xl">
                {o.bio}
              </p>

              {o.stats.length > 0 && (
                <dl class="mt-8 divide-y divide-rule border-t border-rule max-w-xl">
                  {o.stats.map(([k, v]) => (
                    <div class="grid grid-cols-3 gap-4 py-3">
                      <dt class="label col-span-1">{k}</dt>
                      <dd class="col-span-2 text-ink font-mono text-sm">
                        {v}
                      </dd>
                    </div>
                  ))}
                </dl>
              )}
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <!-- Vision -->
  <section class="px-6 md:px-10 mt-24 md:mt-32">
    <div class="mx-auto w-full max-w-[1400px]">
      <header class="pb-8 border-b-2 border-rule">
        <p class="label mb-3">§ 05 — The vision</p>
        <h2 class="serif-head text-5xl md:text-7xl text-ink">What we're after.</h2>
      </header>

      <div class="grid md:grid-cols-3">
        {
          vision.map((v, i) => (
            <div
              class:list={[
                "py-12 md:py-16 md:px-10",
                i !== 2 && "md:border-r border-rule",
                i !== vision.length - 1 && "border-b md:border-b-0 border-rule",
              ]}
            >
              <span class="serif-head text-6xl text-accent italic">{v.n}.</span>
              <h3 class="serif-head text-3xl text-ink mt-2">{v.title}</h3>
              <p class="mt-4 text-muted leading-relaxed">{v.body}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</Layout>
