---
import Layout from "~/layouts/PageLayout.astro";
import Image from "~/components/common/Image.astro";
import bryan from "~/assets/images/bryan.webp";
import amaar from "~/assets/images/amaar.jpg";
import ryan from "~/assets/images/ryan.JPG";
import maya from "~/assets/images/maya.jpg";

const metadata = { title: "About" };

const officers = [
  {
    name: "Bryan Hu",
    role: "Co-President",
    image: bryan,
    alt: "Bryan Hu",
    bio: "I'm a very passionate software developer.",
    stats: [
      {
        title: "5+ years of programming experience",
        description:
          "I have mastery in Python and expertise in programming languages such as Java, C++, Rust, and JavaScript (including various frameworks). I have also made various projects",
      },
      {
        title: "USACO Silver",
        description:
          "The USA Computing Olympiad (USACO) is a programming competition for U.S. middle and high school students, featuring online contests with algorithmic problems with levels ranging from bronze to platnium.",
      },
      {
        title: "Open Source Contributor",
        description:
          "I've contributed to many open source projects and have made several of my own. I have experience with Git, GitHub, and all the various tooling everyone uses.",
      },
    ],
  },
  {
    name: "Amaar Chughtai",
    role: "Co-President",
    image: amaar,
    alt: "Amaar Chughtai",
    bio: "My name is Amaar. I am a 15 year old software engineer in the Bay Area.",
    stats: [
      {
        title: "5+ Years of Programming Experience",
        description:
          "Proficient in programming languages such as C++, Python, Java, JavaScript, SQL, +more. I use a wide variety of frameworks including NextJS, Svelte (sadly), Astro, +more. I have worked on many projects & business technologies.",
      },
      {
        title: "USACO Silver",
        description:
          "The USA Computing Olympiad (USACO) is a programming competition for U.S. middle and high school students, featuring online contests with algorithmic problems with levels ranging from bronze to platnium.",
      },
      {
        title: "Machine Learning Engineer",
        description:
          "I am a machine learning engineer with experience in DL, CV, and NLP. I have studied the mathematics behind DL and have experience with PyTorch, TensorFlow, Keras, +more.",
      },
    ],
  },
  {
    name: "Ryan Abraham",
    role: "Vice President",
    image: ryan,
    alt: "Ryan Abraham",
    bio: "I'm a high school student interested in programming.",
    stats: [
      {
        title: "FTC Team Captain",
        description:
          "I'm a former team captain of FTC team 21463, Delta Robotics. Additionally, I've had the privilege of mentoring two FLL Explore teams, sharing my knowledge and fostering a love for robotics among younger students.",
      },
      {
        title: "5+ years of programming experience",
        description:
          "My technical skills span a variety of languages and frameworks including Java, Python, C++, HTML, CSS, Svelte, React, PostgreSQL, and Kotlin.",
      },
    ],
  },
  {
    name: "Maya Rao",
    role: "Head of Business",
    image: maya,
    alt: "Maya Rao",
    bio: null,
    stats: [],
  },
];

const vision = [
  {
    title: "empower",
    body: "I want our club to bring the very best out of people, allowing them to build great things without anything to slow them down.",
  },
  {
    title: "impact",
    body: "I want to be able to create a tangible impact on the world what we do (in a positive way), which includes reaching out to the local community",
  },
  {
    title: "last",
    body: "I don't want this club to just die out when I graduate but instead, I want it to be a club that lasts for a long time. A long enough time that it can create a real impact on the next generation of software engineers",
  },
];
---

<Layout metadata={metadata}>
  <!-- HERO -->
  <section class="page-gutter pt-10 md:pt-20">
    <p class="eyebrow mb-6">About</p>
    <h1
      class="display text-ink max-w-[16ch]"
      style="font-size: clamp(2.5rem, 6.5vw, 5rem);"
    >
      Built by high schoolers.<br />
      For <span class="italic">high schoolers</span>.
    </h1>
    <p class="prose-lead mt-8 max-w-xl">
      We are just a group of high school students who are passionate about
      software development — teaching the course we wish we'd had.
    </p>
  </section>

  <!-- OFFICERS -->
  <section class="page-gutter mt-28 md:mt-36">
    <header class="flex items-baseline justify-between pb-5 mb-14 md:mb-20 border-b border-rule">
      <h2
        class="display-tight text-ink"
        style="font-size: clamp(1.5rem, 2.2vw, 2rem);"
      >
        Meet the team.
      </h2>
      <p class="eyebrow hidden md:block">Four officers</p>
    </header>

    <div class="flex flex-col gap-24 md:gap-32">
      {
        officers.map((o, i) => (
          <article class="grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-12 items-start">
            <figure
              class:list={[
                "md:col-span-5",
                i % 2 === 1 && "md:order-2 md:col-start-8",
              ]}
            >
              <Image
                src={o.image}
                alt={o.alt}
                widths={[400, 800]}
                sizes="(max-width: 768px) 100vw, 40vw"
                class="w-full h-auto block bg-raised"
              />
              <figcaption class="caption mt-3">{o.name}.</figcaption>
            </figure>

            <div
              class:list={[
                "md:col-span-6",
                i % 2 === 1 ? "md:order-1 md:col-start-1" : "md:col-start-7",
              ]}
            >
              <p class="eyebrow mb-3">{o.role}</p>
              <h3
                class="display text-ink"
                style="font-size: clamp(2rem, 4vw, 3.25rem);"
              >
                {o.name}
              </h3>
              {o.bio && (
                <p class="prose-lead mt-6 max-w-xl italic">{o.bio}</p>
              )}

              {o.stats.length > 0 && (
                <dl class="mt-8 divide-y divide-rule border-t border-rule">
                  {o.stats.map((s) => (
                    <div class="py-5">
                      <dt
                        class="display-tight text-ink mb-2"
                        style="font-size: 1.125rem;"
                      >
                        {s.title}
                      </dt>
                      <dd class="text-ink-soft leading-relaxed">
                        {s.description}
                      </dd>
                    </div>
                  ))}
                </dl>
              )}
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <!-- VISION -->
  <section class="page-gutter mt-28 md:mt-36">
    <figure class="max-w-[62ch]">
      <p class="eyebrow mb-5">Our vision</p>
      <blockquote class="text-ink">
        <p
          class="display-tight"
          style="font-size: clamp(1.875rem, 3.2vw, 2.75rem); line-height: 1.15;"
        >
          I take this very seriously.
        </p>
        <p
          class="display-tight mt-6 text-ink-soft"
          style="font-size: clamp(1.0625rem, 1.4vw, 1.25rem); line-height: 1.55;"
        >
          Too many kids these days are forced into learning programming,
          especially competitive programming. So they learn, because they were
          forced to learn. But then afterwards, they realize that their skills
          are put to waste as they did not know how to put them into practical
          use.
        </p>
        <p
          class="display-tight italic mt-6"
          style="font-size: clamp(1.5rem, 2.4vw, 2rem); line-height: 1.2;"
        >
          I want to change that with this club.
        </p>
      </blockquote>
      <figcaption class="eyebrow mt-8">
        <span class="text-ink">Bryan Hu</span>, Co-President
      </figcaption>
    </figure>

    <ol class="mt-20 grid grid-cols-1 md:grid-cols-3 gap-x-8 gap-y-10 max-w-[1100px]">
      {
        vision.map((v, i) => (
          <li>
            <span
              class="font-mono text-ink-soft"
              style="font-size: 0.75rem;"
            >
              0{i + 1}
            </span>
            <h3
              class="display-tight text-ink mt-2 mb-3"
              style="font-size: 1.375rem;"
            >
              To <span class="italic">{v.title}</span>
            </h3>
            <p class="text-ink-soft leading-relaxed">{v.body}</p>
          </li>
        ))
      }
    </ol>
  </section>
</Layout>
