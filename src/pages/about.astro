---
import Layout from "~/layouts/PageLayout.astro";
import Image from "~/components/common/Image.astro";
import bryan from "~/assets/images/bryan.webp";
import amaar from "~/assets/images/amaar.jpg";
import ryan from "~/assets/images/ryan.JPG";
import maya from "~/assets/images/maya.jpg";

const metadata = { title: "About" };

const officers = [
  {
    name: "Bryan Hu",
    role: "Co-President",
    image: bryan,
    alt: "Bryan Hu",
    bio: "I'm a very passionate software developer.",
    stats: [
      {
        title: "5+ years of programming experience",
        description:
          "I have mastery in Python and expertise in programming languages such as Java, C++, Rust, and JavaScript (including various frameworks). I have also made various projects",
      },
      {
        title: "USACO Silver",
        description:
          "The USA Computing Olympiad (USACO) is a programming competition for U.S. middle and high school students, featuring online contests with algorithmic problems with levels ranging from bronze to platnium.",
      },
      {
        title: "Open Source Contributor",
        description:
          "I've contributed to many open source projects and have made several of my own. I have experience with Git, GitHub, and all the various tooling everyone uses.",
      },
    ],
  },
  {
    name: "Amaar Chughtai",
    role: "Co-President",
    image: amaar,
    alt: "Amaar Chughtai",
    bio: "My name is Amaar. I am a 15 year old software engineer in the Bay Area.",
    stats: [
      {
        title: "5+ Years of Programming Experience",
        description:
          "Proficient in programming languages such as C++, Python, Java, JavaScript, SQL, +more. I use a wide variety of frameworks including NextJS, Svelte (sadly), Astro, +more. I have worked on many projects & business technologies.",
      },
      {
        title: "USACO Silver",
        description:
          "The USA Computing Olympiad (USACO) is a programming competition for U.S. middle and high school students, featuring online contests with algorithmic problems with levels ranging from bronze to platnium.",
      },
      {
        title: "Machine Learning Engineer",
        description:
          "I am a machine learning engineer with experience in DL, CV, and NLP. I have studied the mathematics behind DL and have experience with PyTorch, TensorFlow, Keras, +more.",
      },
    ],
  },
  {
    name: "Ryan Abraham",
    role: "Vice President",
    image: ryan,
    alt: "Ryan Abraham",
    bio: "I'm a high school student interested in programming.",
    stats: [
      {
        title: "FTC Team Captain",
        description:
          "I'm a former team captain of FTC team 21463, Delta Robotics. Additionally, I've had the privilege of mentoring two FLL Explore teams, sharing my knowledge and fostering a love for robotics among younger students.",
      },
      {
        title: "5+ years of programming experience",
        description:
          "My technical skills span a variety of languages and frameworks including Java, Python, C++, HTML, CSS, Svelte, React, PostgreSQL, and Kotlin.",
      },
    ],
  },
  {
    name: "Maya Rao",
    role: "Head of Business",
    image: maya,
    alt: "Maya Rao",
    bio: null,
    stats: [],
  },
];

const vision = [
  {
    title: "empower",
    body: "I want our club to bring the very best out of people, allowing them to build great things without anything to slow them down.",
  },
  {
    title: "impact",
    body: "I want to be able to create a tangible impact on the world what we do (in a positive way), which includes reaching out to the local community",
  },
  {
    title: "last",
    body: "I don't want this club to just die out when I graduate but instead, I want it to be a club that lasts for a long time. A long enough time that it can create a real impact on the next generation of software engineers",
  },
];
---

<Layout metadata={metadata}>
  <!-- HERO -->
  <section class="page-gutter pt-12 md:pt-20">
    <p class="path mb-10">~/about</p>
    <h1
      class="display text-ink max-w-[16ch]"
      style="font-size: clamp(2.5rem, 7vw, 5.5rem);"
    >
      Built by high schoolers.<br />For high schoolers.
    </h1>
    <p class="prose-lead mt-8 max-w-[52ch]">
      We are just a group of high school students who are passionate about
      software development — teaching the course we wish we'd had.
    </p>
  </section>

  <!-- OFFICERS -->
  <section class="page-gutter mt-32 md:mt-40">
    <div class="grid grid-cols-12 gap-6">
      <div class="col-span-12 lg:col-span-1">
        <p class="section-numeral">§ 01</p>
      </div>
      <header class="col-span-12 lg:col-span-11 border-t border-rule pt-8 pb-10 flex items-baseline justify-between">
        <h2
          class="display-tight text-ink"
          style="font-size: clamp(1.5rem, 2.4vw, 2rem);"
        >
          Meet the team.
        </h2>
        <p class="tag hidden md:block">[n = 4]</p>
      </header>
    </div>

    <div class="flex flex-col">
      {
        officers.map((o, i) => (
          <article
            class:list={[
              "grid grid-cols-12 gap-x-6 gap-y-8 border-t border-rule-soft py-14 md:py-20",
              i === officers.length - 1 && "border-b border-rule-soft",
            ]}
          >
            <!-- index marker -->
            <div class="col-span-12 md:col-span-1">
              <p class="lineno">
                {String(i + 1).padStart(2, "0")}/{String(officers.length).padStart(2, "0")}
              </p>
            </div>

            <!-- photo -->
            <figure
              class:list={[
                "col-span-12 md:col-span-5",
                i % 2 === 1 && "md:order-2 md:col-start-7",
              ]}
            >
              <Image
                src={o.image}
                alt={o.alt}
                widths={[400, 800]}
                sizes="(max-width: 768px) 100vw, 40vw"
                class="w-full h-auto block"
              />
              <figcaption class="mt-3 flex items-baseline gap-3 border-t border-rule-soft pt-2">
                <span class="lineno">fig.{String(i + 1).padStart(2, "0")}</span>
                <span class="caption">{o.name.toLowerCase()}</span>
              </figcaption>
            </figure>

            <!-- bio + stats -->
            <div
              class:list={[
                "col-span-12 md:col-span-6",
                i % 2 === 1 ? "md:order-1 md:col-start-2" : "md:col-start-8",
              ]}
            >
              <p class="tag mb-3">{o.role.toLowerCase()}</p>
              <h3
                class="display text-ink"
                style="font-size: clamp(2rem, 4vw, 3rem);"
              >
                {o.name}
              </h3>
              {o.bio && (
                <p class="prose-lead mt-5 max-w-[48ch] italic">{o.bio}</p>
              )}

              {o.stats.length > 0 && (
                <dl class="mt-8 border-t border-rule">
                  {o.stats.map((s, si) => (
                    <div class="py-5 border-b border-rule-soft grid grid-cols-[auto_1fr] gap-5">
                      <span class="lineno pt-1">
                        {String(si + 1).padStart(2, "0")}
                      </span>
                      <div>
                        <dt
                          class="display-tight text-ink mb-2"
                          style="font-size: 1.0625rem;"
                        >
                          {s.title}
                        </dt>
                        <dd class="text-ink-soft leading-relaxed text-[0.9375rem]">
                          {s.description}
                        </dd>
                      </div>
                    </div>
                  ))}
                </dl>
              )}
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <!-- VISION -->
  <section class="page-gutter mt-32 md:mt-40">
    <div class="grid grid-cols-12 gap-6">
      <div class="col-span-12 lg:col-span-1 lg:pt-2">
        <p class="section-numeral">§ 02</p>
      </div>
      <div class="col-span-12 lg:col-span-9 lg:col-start-3 border-t border-rule pt-10">
        <figure class="max-w-[62ch]">
          <p class="path mb-10">~/about/vision</p>
          <blockquote class="text-ink">
            <p
              class="display-tight"
              style="font-size: clamp(2rem, 4vw, 3.25rem);"
            >
              I take this very seriously.
            </p>
            <p
              class="display-tight mt-8 text-ink-soft max-w-[58ch]"
              style="font-size: clamp(1.0625rem, 1.3vw, 1.1875rem); line-height: 1.55; font-stretch: 100%; font-weight: 400; letter-spacing: 0;"
            >
              Too many kids these days are forced into learning programming,
              especially competitive programming. So they learn, because they
              were forced to learn. But then afterwards, they realize that
              their skills are put to waste as they did not know how to put
              them into practical use.
            </p>
            <p
              class="display-tight mt-8"
              style="font-size: clamp(1.5rem, 2.6vw, 2.25rem); color: var(--aw-color-accent);"
            >
              I want to change that with this club.
            </p>
          </blockquote>
          <figcaption class="mt-10 flex items-baseline gap-3 border-t border-rule-soft pt-3">
            <span class="lineno">—</span>
            <span class="mono text-[0.8125rem] text-ink">Bryan Hu</span>
            <span class="caption">co-president</span>
          </figcaption>
        </figure>
      </div>
    </div>

    <ol class="mt-20 grid grid-cols-12 gap-6 border-t border-rule">
      {
        vision.map((v, i) => (
          <li
            class:list={[
              "col-span-12 md:col-span-4 p-6 md:p-8 border-b border-rule-soft",
              i < vision.length - 1 && "md:border-r md:border-rule-soft",
            ]}
          >
            <p class="lineno mb-4">
              0{i + 1} / 03
            </p>
            <h3
              class="display-tight text-ink mb-3"
              style="font-size: 1.375rem;"
            >
              To <span style="color: var(--aw-color-accent);">{v.title}</span>
            </h3>
            <p class="text-ink-soft leading-relaxed text-[0.9375rem]">{v.body}</p>
          </li>
        ))
      }
    </ol>
  </section>
</Layout>
