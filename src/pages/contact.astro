---
import Layout from "~/layouts/PageLayout.astro";

const metadata = { title: "Contact" };

const channels = [
  {
    label: "Email",
    handle: "vchs.software@gmail.com",
    href: "mailto:vchs.software@gmail.com",
    note: "Fastest way to reach the officers. Questions, ideas, collabs — all welcome.",
  },
  {
    label: "Discord",
    handle: "discord.gg/hayb3xUZRD",
    href: "https://discord.gg/hayb3xUZRD",
    note: "Where members hang out between meetings. Come ask a question or show off a project.",
  },
  {
    label: "Instagram",
    handle: "@vchs_software",
    href: "https://www.instagram.com/vchs_software",
    note: "Announcements and meeting recaps, mostly.",
  },
];
---

<Layout metadata={metadata}>
  <section class="page-gutter pt-10 md:pt-20">
    <p class="eyebrow mb-6">Contact</p>
    <h1
      class="display text-ink max-w-[14ch]"
      style="font-size: clamp(2.5rem, 7vw, 5.5rem);"
    >
      Let's <span class="italic">connect</span>.
    </h1>
    <p class="prose-lead mt-8 max-w-xl">
      Pick whichever channel suits you. We read them all.
    </p>
  </section>

  <section class="page-gutter mt-24 md:mt-32">
    <ol>
      {
        channels.map((c, i) => (
          <li
            class:list={[
              "border-t border-rule",
              i === channels.length - 1 && "border-b",
            ]}
          >
            <a
              href={c.href}
              target={c.href.startsWith("http") ? "_blank" : undefined}
              rel={c.href.startsWith("http") ? "noopener noreferrer" : undefined}
              class="group grid grid-cols-1 md:grid-cols-12 gap-4 md:gap-10 py-8 md:py-10 items-baseline transition-colors hover:bg-raised/60"
            >
              <p class="eyebrow md:col-span-2">{c.label}</p>
              <div class="md:col-span-8">
                <p
                  class="display-tight text-ink group-hover:text-accent transition-colors"
                  style="font-size: clamp(1.25rem, 2vw, 1.75rem);"
                >
                  {c.handle}
                </p>
                <p class="text-ink-soft mt-2 leading-relaxed max-w-lg">
                  {c.note}
                </p>
              </div>
              <span
                class="arrow md:col-span-2 md:text-right text-ink-soft group-hover:text-accent"
                style="font-size: 1.125rem;"
                aria-hidden="true"
              >
                →
              </span>
            </a>
          </li>
        ))
      }
    </ol>
  </section>
</Layout>
