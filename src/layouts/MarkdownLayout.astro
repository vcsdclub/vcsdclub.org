---
import Layout from '~/layouts/PageLayout.astro';

import type { MetaData } from '~/types';

export interface Props {
  frontmatter: {
    title?: string;
  };
}

const { frontmatter } = Astro.props;

const metadata: MetaData = {
  title: frontmatter?.title,
};
---

<Layout metadata={metadata}>
  <section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 lg:py-20 max-w-4xl">
    <h1 class="display text-ink text-4xl md:text-5xl leading-tighter tracking-tighter">{frontmatter.title}</h1>
    <div
      class="mx-auto prose prose-lg max-w-4xl prose-md prose-headings:font-heading prose-headings:leading-tighter prose-headings:tracking-tighter prose-headings:font-bold prose-img:rounded-md prose-img:shadow-lg mt-8"
      style="--tw-prose-body: var(--aw-color-ink); --tw-prose-headings: var(--aw-color-ink); --tw-prose-bold: var(--aw-color-ink); --tw-prose-links: var(--aw-color-riso); --tw-prose-bullets: var(--aw-color-muted); --tw-prose-counters: var(--aw-color-muted); --tw-prose-quotes: var(--aw-color-ink-soft); --tw-prose-quote-borders: var(--aw-color-rule-soft); --tw-prose-hr: var(--aw-color-rule-soft); --tw-prose-th-borders: var(--aw-color-rule-soft); --tw-prose-td-borders: var(--aw-color-rule-soft); --tw-prose-code: var(--aw-color-ink); color: var(--aw-color-ink);"
    >
      <slot />
    </div>
  </section>
</Layout>
