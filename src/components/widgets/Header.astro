---
import Logo from "~/components/Logo.astro";
import ToggleMenu from "~/components/common/ToggleMenu.astro";
import ToggleTheme from "~/components/common/ToggleTheme.astro";
import { trimSlash } from "~/utils/permalinks";

interface Link {
  text?: string;
  href?: string;
}

interface ActionLink {
  text: string;
  href: string;
  target?: string;
}

export interface Props {
  id?: string;
  links?: Array<Link>;
  actions?: Array<ActionLink>;
  isSticky?: boolean;
  showToggleTheme?: boolean;
}

const {
  id = "header",
  links = [],
  actions = [],
  isSticky = false,
  showToggleTheme = false,
} = Astro.props;

const currentPath = `/${trimSlash(new URL(Astro.url).pathname)}`;
---

<header
  class:list={[
    { sticky: isSticky, relative: !isSticky },
    "top-0 z-40 w-full bg-page/90 backdrop-blur-md",
  ]}
  {...isSticky ? { "data-aw-sticky-header": true } : {}}
  {...id ? { id } : {}}
>
  <div class="relative">
    <div
      class="page-gutter py-4 flex items-center justify-between gap-6 border-b border-rule-soft"
    >
      <Logo />

      <nav class="hidden md:flex items-center gap-7" aria-label="Main">
        {
          links.map(({ text, href }) => {
            const active = href === currentPath;
            return (
              <a
                href={href}
                class:list={[
                  "mono text-[0.8125rem] font-medium transition-colors hover:text-accent",
                  active ? "text-accent" : "text-ink-soft",
                ]}
              >
                {text?.toLowerCase()}
              </a>
            );
          })
        }
      </nav>

      <div class="flex items-center gap-4">
        {
          showToggleTheme && (
            <ToggleTheme iconClass="w-4 h-4 text-ink-soft hover:text-accent transition-colors" />
          )
        }
        {
          actions.map((a) => (
            <a
              href={a.href}
              target={a.target}
              rel={a.target === "_blank" ? "noopener noreferrer" : undefined}
              class="prompt hidden md:inline-flex"
            >
              {a.text.toLowerCase()}
              <span class="arrow" aria-hidden="true">→</span>
            </a>
          ))
        }
        <div class="md:hidden">
          <ToggleMenu />
        </div>
      </div>
    </div>

    <!-- Mobile drawer -->
    <div
      data-mobile-drawer
      class="md:hidden hidden absolute left-0 right-0 top-full bg-page border-b border-rule px-6 py-8"
    >
      <nav class="flex flex-col gap-1" aria-label="Mobile">
        {
          links.map(({ text, href }, i) => {
            const active = href === currentPath;
            return (
              <a
                href={href}
                class:list={[
                  "mono text-base py-3 border-b border-rule-soft transition-colors hover:text-accent flex items-baseline gap-3",
                  active ? "text-accent" : "text-ink",
                ]}
              >
                <span class="lineno">{String(i + 1).padStart(2, "0")}</span>
                <span>{text?.toLowerCase()}</span>
              </a>
            );
          })
        }
        {
          actions.map((a) => (
            <a
              href={a.href}
              target={a.target}
              rel={a.target === "_blank" ? "noopener noreferrer" : undefined}
              class="prompt mt-6 self-start"
            >
              {a.text.toLowerCase()}
              <span class="arrow" aria-hidden="true">→</span>
            </a>
          ))
        }
      </nav>
    </div>
  </div>
</header>

<script>
  const init = () => {
    const toggle = document.querySelector("[data-aw-toggle-menu]");
    const drawer = document.querySelector("[data-mobile-drawer]");
    if (!toggle || !drawer) return;

    const handler = () => {
      toggle.classList.toggle("expanded");
      drawer.classList.toggle("hidden");
    };

    toggle.addEventListener("click", handler);

    const reset = () => {
      toggle.classList.remove("expanded");
      drawer.classList.add("hidden");
    };
    window.matchMedia("(min-width: 768px)").addEventListener("change", reset);

    drawer.querySelectorAll("a").forEach((a) =>
      a.addEventListener("click", reset)
    );
  };

  init();
  document.addEventListener("astro:after-swap", init);
</script>
