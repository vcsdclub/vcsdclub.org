---
import { Icon } from "astro-icon/components";

interface Link {
  text?: string;
  href?: string;
  ariaLabel?: string;
  icon?: string;
}

export interface Props {
  secondaryLinks?: Array<Link>;
  socialLinks?: Array<Link>;
  footNote?: string;
}

const { secondaryLinks = [], socialLinks = [] } = Astro.props;
const year = new Date().getFullYear();

const nav = [
  { text: "home", href: "/" },
  { text: "about", href: "/about" },
  { text: "resources", href: "/resources" },
  { text: "contact", href: "/contact" },
];
---

<footer class="mt-32 md:mt-44 border-t border-rule">
  <div class="page-gutter pt-14 md:pt-20 pb-10">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 md:gap-10">
      <div class="md:col-span-6">
        <p class="path mb-4">~/sdclub.vchs</p>
        <p
          class="display-tight text-ink leading-tight"
          style="font-size: clamp(1.625rem, 2.6vw, 2.25rem);"
        >
          Valley Christian<br />Software Development Club.
        </p>
        <p class="mt-5 text-ink-soft max-w-md leading-relaxed text-[0.9375rem]">
          A student-run club teaching the craft of real software engineering.
          Free, forever.
        </p>
      </div>

      <div class="md:col-span-3">
        <p class="tag mb-5">navigate</p>
        <ul class="space-y-2.5">
          {
            nav.map((n, i) => (
              <li class="flex items-baseline gap-3">
                <span class="lineno">
                  {String(i + 1).padStart(2, "0")}
                </span>
                <a href={n.href} class="link mono text-[0.875rem]">
                  {n.text}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="md:col-span-3">
        <p class="tag mb-5">elsewhere</p>
        <ul class="space-y-2.5">
          {
            socialLinks.map(({ ariaLabel, icon, href }, i) => (
              <li class="flex items-baseline gap-3">
                <span class="lineno">
                  {String(i + 1).padStart(2, "0")}
                </span>
                <a
                  href={href}
                  aria-label={ariaLabel}
                  class="link mono text-[0.875rem] inline-flex items-center gap-2"
                >
                  {icon && <Icon name={icon} class="w-3.5 h-3.5" />}
                  <span>{ariaLabel?.toLowerCase()}</span>
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <div
      class="mt-16 pt-5 border-t border-rule-soft flex flex-col md:flex-row md:items-center md:justify-between gap-4"
    >
      <p class="caption">
        &copy; {year} — valley christian software development club
      </p>
      <ul class="flex flex-wrap gap-5">
        {
          secondaryLinks.map(({ text, href }) => (
            <li>
              <a href={href} class="caption hover:text-ink transition-colors">
                {text}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</footer>
