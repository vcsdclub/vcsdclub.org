---
import { Icon } from "astro-icon/components";

interface Link {
  text?: string;
  href?: string;
  ariaLabel?: string;
  icon?: string;
}

export interface Props {
  secondaryLinks?: Array<Link>;
  socialLinks?: Array<Link>;
  footNote?: string;
}

const { secondaryLinks = [], socialLinks = [] } = Astro.props;
const year = new Date().getFullYear();

const nav = [
  { text: "home", href: "/" },
  { text: "about", href: "/about" },
  { text: "resources", href: "/resources" },
  { text: "contact", href: "/contact" },
];
---

<footer class="mt-32 md:mt-44 border-t-2 border-ink">
  <!-- giant wordmark bleed -->
  <div class="page-gutter pt-16 md:pt-24 pb-10">
    <div class="grid grid-cols-12 gap-x-6 gap-y-10">
      <div class="col-span-12 md:col-span-7">
        <span class="ribbon mb-6">colophon</span>
        <p
          class="display text-ink leading-none mt-6"
          style="font-size: clamp(3rem, 9vw, 7.5rem);"
        >
          <span>SD</span><span class="text-riso">.</span><span>CLUB</span>
        </p>
        <p
          class="hand mt-4"
          style="font-size: clamp(1.75rem, 3.5vw, 2.5rem); transform: rotate(-2deg); display: inline-block;"
        >
          free, forever.
        </p>
        <p class="mt-6 text-ink max-w-md leading-relaxed text-[0.9375rem]">
          A student-run club teaching the craft of real software engineering —
          at Valley Christian High School, in San Jose, on earth.
        </p>
      </div>

      <div class="col-span-6 md:col-span-2 md:col-start-9">
        <p class="tag mb-5">nav</p>
        <ul class="space-y-2.5">
          {
            nav.map((n) => (
              <li>
                <a href={n.href} class="link font-mono text-[0.875rem] uppercase tracking-wide">
                  {n.text}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="col-span-6 md:col-span-3">
        <p class="tag mb-5">elsewhere</p>
        <ul class="space-y-2.5">
          {
            socialLinks.map(({ ariaLabel, icon, href }) => (
              <li>
                <a
                  href={href}
                  aria-label={ariaLabel}
                  class="link font-mono text-[0.875rem] uppercase tracking-wide inline-flex items-center gap-2"
                >
                  {icon && <Icon name={icon} class="w-3.5 h-3.5" />}
                  <span>{ariaLabel}</span>
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <div
      class="mt-20 pt-5 border-t border-rule-soft flex flex-col md:flex-row md:items-center md:justify-between gap-4"
    >
      <p class="caption">
        &copy; {year} — printed in ink &amp; pink
      </p>
      <ul class="flex flex-wrap gap-5">
        {
          secondaryLinks.map(({ text, href }) => (
            <li>
              <a href={href} class="caption hover:text-riso transition-colors">
                {text}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</footer>
