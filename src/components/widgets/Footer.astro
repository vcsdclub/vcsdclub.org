---
import { Icon } from "astro-icon/components";

interface Link {
  text?: string;
  href?: string;
  ariaLabel?: string;
  icon?: string;
}

export interface Props {
  secondaryLinks?: Array<Link>;
  socialLinks?: Array<Link>;
  footNote?: string;
}

const { secondaryLinks = [], socialLinks = [] } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="mt-32 border-t border-rule">
  <div class="mx-auto w-full max-w-[1400px] px-6 md:px-10 py-12 md:py-16">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-10 md:gap-8">
      <div class="md:col-span-6">
        <p class="label mb-4">Colophon</p>
        <p class="serif-head text-3xl md:text-4xl text-ink leading-tight">
          VCHS Software<br />Development Club
        </p>
        <p class="mt-6 text-muted max-w-md leading-relaxed">
          A student-run club at Valley Christian High School teaching the craft
          of real software engineering. Free, forever.
        </p>
      </div>

      <div class="md:col-span-3">
        <p class="label mb-4">Navigate</p>
        <ul class="space-y-2">
          <li><a href="/" class="link">Home</a></li>
          <li><a href="/about" class="link">About</a></li>
          <li><a href="/resources" class="link">Resources</a></li>
          <li><a href="/contact" class="link">Contact</a></li>
        </ul>
      </div>

      <div class="md:col-span-3">
        <p class="label mb-4">Elsewhere</p>
        <ul class="space-y-2">
          {
            socialLinks.map(({ ariaLabel, icon, href }) => (
              <li>
                <a
                  href={href}
                  aria-label={ariaLabel}
                  class="link inline-flex items-center gap-2"
                >
                  {icon && <Icon name={icon} class="w-4 h-4" />}
                  <span>{ariaLabel}</span>
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <div
      class="mt-16 pt-6 border-t border-rule flex flex-col md:flex-row md:items-center md:justify-between gap-4"
    >
      <p class="font-mono text-xs text-muted">
        © {year} · Valley Christian Software Development Club
      </p>
      <ul class="flex flex-wrap gap-5">
        {
          secondaryLinks.map(({ text, href }) => (
            <li>
              <a
                href={href}
                class="font-mono text-xs text-muted hover:text-ink"
              >
                {text}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</footer>
