---
import { Icon } from "astro-icon/components";

interface Link {
  text?: string;
  href?: string;
  ariaLabel?: string;
  icon?: string;
}

export interface Props {
  secondaryLinks?: Array<Link>;
  socialLinks?: Array<Link>;
  footNote?: string;
}

const { secondaryLinks = [], socialLinks = [] } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="mt-32 md:mt-44 border-t border-rule">
  <div class="page-gutter py-14 md:py-20">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-10 md:gap-8">
      <div class="md:col-span-6">
        <p class="display-tight text-ink text-2xl md:text-[1.75rem] leading-tight max-w-md">
          VCHS Software<br />Development Club
        </p>
        <p class="mt-5 text-ink-soft max-w-md leading-relaxed">
          A student-run club teaching the craft of real software engineering.
          Free, forever.
        </p>
      </div>

      <div class="md:col-span-3">
        <p class="eyebrow mb-4">Navigate</p>
        <ul class="space-y-2">
          <li><a href="/" class="link">Home</a></li>
          <li><a href="/about" class="link">About</a></li>
          <li><a href="/resources" class="link">Resources</a></li>
          <li><a href="/contact" class="link">Contact</a></li>
        </ul>
      </div>

      <div class="md:col-span-3">
        <p class="eyebrow mb-4">Elsewhere</p>
        <ul class="space-y-2">
          {
            socialLinks.map(({ ariaLabel, icon, href }) => (
              <li>
                <a
                  href={href}
                  aria-label={ariaLabel}
                  class="link inline-flex items-center gap-2"
                >
                  {icon && <Icon name={icon} class="w-4 h-4" />}
                  <span>{ariaLabel}</span>
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <div
      class="mt-14 pt-6 border-t border-rule flex flex-col md:flex-row md:items-center md:justify-between gap-4"
    >
      <p class="caption">
        © {year} · Valley Christian Software Development Club
      </p>
      <ul class="flex flex-wrap gap-5">
        {
          secondaryLinks.map(({ text, href }) => (
            <li>
              <a href={href} class="caption hover:text-ink transition-colors">
                {text}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</footer>
