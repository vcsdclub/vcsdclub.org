---
import { Icon } from "astro-icon/components";
import { UI } from "astrowind:config";

export interface Props {
  label?: string;
  class?: string;
  iconClass?: string;
}

const {
  label = "Toggle between Dark and Light mode",
  class: className = "inline-flex items-center justify-center p-2 rounded-full hover:bg-raised transition-colors",
  iconClass = "w-4 h-4",
} = Astro.props;
---

{
  !(UI.theme && UI.theme.endsWith(":only")) && (
    <button
      type="button"
      class={className}
      aria-label={label}
      data-aw-toggle-color-scheme
    >
      <Icon name="tabler:sun" class={`${iconClass} dark:hidden`} />
      <Icon name="tabler:moon" class={`${iconClass} hidden dark:block`} />
    </button>
  )
}
