---
export interface Props {
  label?: string;
  class?: string;
}

const {
  label = "Toggle Menu",
  class: className = "flex flex-col h-10 w-10 justify-center items-center cursor-pointer group -mr-2",
} = Astro.props;
---

<button type="button" class={className} aria-label={label} data-aw-toggle-menu>
  <span class="sr-only">{label}</span>
  <slot>
    <span
      aria-hidden="true"
      class="h-px w-6 my-[5px] bg-ink transition-all duration-200 group-[.expanded]:rotate-45 group-[.expanded]:translate-y-[6px]"
    ></span>
    <span
      aria-hidden="true"
      class="h-px w-6 my-[5px] bg-ink transition-all duration-200 group-[.expanded]:-rotate-45 group-[.expanded]:-translate-y-[6px]"
    ></span>
  </slot>
</button>
