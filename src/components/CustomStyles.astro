---
import "@fontsource-variable/archivo";
import "@fontsource-variable/space-grotesk";
import "@fontsource/gloock";
import "@fontsource/caveat";
import "@fontsource-variable/jetbrains-mono";
---

<style is:inline>
  :root {
    --aw-font-sans: "Archivo Variable", ui-sans-serif, system-ui, sans-serif;
    --aw-font-display: "Space Grotesk Variable", "Archivo Variable",
      ui-sans-serif, sans-serif;
    --aw-font-serif: "Gloock", ui-serif, Georgia, serif;
    --aw-font-hand: "Caveat", "Space Grotesk Variable", cursive;
    --aw-font-heading: "Space Grotesk Variable", ui-sans-serif, sans-serif;
    --aw-font-mono: "JetBrains Mono Variable", ui-monospace, SFMono-Regular,
      Menlo, monospace;

    /* Paper & ink — inverted: black paper, bone-white ink */
    --aw-color-bg-page: #0a0a08;
    --aw-color-bg-raised: #15151080;
    --aw-color-ink: #f3eee1;
    --aw-color-ink-soft: #c7bfae;
    --aw-color-muted: #7e7668;
    --aw-color-rule: #f3eee1;
    --aw-color-rule-soft: #2a2620;

    /* Riso — cyan-blue accent */
    --aw-color-riso: #4ba2ce;
    --aw-color-riso-ink: #6fb8dc;

    /* Legacy aliases */
    --aw-color-accent: var(--aw-color-riso);
    --aw-color-accent-ink: var(--aw-color-riso-ink);
    --aw-color-primary: var(--aw-color-ink);
    --aw-color-secondary: var(--aw-color-ink-soft);
    --aw-color-text-heading: var(--aw-color-ink);
    --aw-color-text-default: var(--aw-color-ink);
    --aw-color-text-muted: var(--aw-color-muted);
    --aw-color-bg-page-dark: #120f0a;
  }

  /* Dark is the default here — light mode inverts to paper */
  .dark {
    --aw-color-bg-page: #f3eee1;
    --aw-color-bg-raised: #e8e1cf;
    --aw-color-ink: #0a0a08;
    --aw-color-ink-soft: #2a2620;
    --aw-color-muted: #6e6150;
    --aw-color-rule: #0a0a08;
    --aw-color-rule-soft: #c2b9a5;

    --aw-color-riso: #2b7fa5;
    --aw-color-riso-ink: #236b8c;

    --aw-color-accent: var(--aw-color-riso);
    --aw-color-accent-ink: var(--aw-color-riso-ink);
    --aw-color-text-heading: var(--aw-color-ink);
    --aw-color-text-default: var(--aw-color-ink);
    --aw-color-text-muted: var(--aw-color-muted);
  }

  html {
    font-family: var(--aw-font-sans);
    color: var(--aw-color-ink);
    background-color: var(--aw-color-bg-page);
  }

  /* Photocopy grain — lightens black subtly, fixed viewport */
  body::before {
    content: "";
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    opacity: 0.22;
    mix-blend-mode: screen;
    background-image: url("data:image/svg+xml;utf8,<svg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='2' stitchTiles='stitch'/><feColorMatrix values='0 0 0 0 0.95  0 0 0 0 0.93  0 0 0 0 0.88  0 0 0 0.4 0'/></filter><rect width='100%' height='100%' filter='url(%23n)'/></svg>");
    background-size: 160px 160px;
  }
  /* Horizontal scanline overlay — very subtle */
  body::after {
    content: "";
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    opacity: 0.08;
    background-image: repeating-linear-gradient(
      to bottom,
      transparent 0,
      transparent 2px,
      rgba(0, 0, 0, 0.9) 2px,
      rgba(0, 0, 0, 0.9) 3px
    );
  }
  body > * {
    position: relative;
    z-index: 1;
  }

  .font-display {
    font-family: var(--aw-font-display);
  }
  .font-serif {
    font-family: var(--aw-font-serif);
  }
  .font-hand {
    font-family: var(--aw-font-hand);
  }
  .font-mono {
    font-family: var(--aw-font-mono);
  }
</style>
